{
  "name": "@resolid/app-log",
  "version": "0.0.0",
  "private": true,
  "description": "Logging module for Resolid applications",
  "keywords": [
    "log",
    "logger",
    "logging",
    "resolid"
  ],
  "homepage": "https://www.resolid.tech",
  "license": "MIT",
  "author": {
    "name": "Huijie Wei",
    "email": "hello@resolid.tech"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resolid/framework.git",
    "directory": "packages/app-log"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./targets": {
      "types": "./dist/targets.d.mts",
      "import": "./dist/targets.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@logtape/logtape": "^2.2.2",
    "@resolid/core": "workspace:^"
  },
  "devDependencies": {
    "tsdown": "^0.22.3"
  },
  "peerDependencies": {
    "@logtape/file": "^2.2.2"
  },
  "peerDependenciesMeta": {
    "@logtape/file": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.22.0 || >=24"
  }
}
