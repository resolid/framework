{
  "name": "@resolid/dev",
  "version": "0.8.0",
  "private": false,
  "description": "Development utils for Resolid applications",
  "keywords": [
    "netlify",
    "nodejs",
    "react-router",
    "resolid",
    "vercel",
    "vite"
  ],
  "homepage": "https://www.resolid.tech",
  "license": "MIT",
  "author": {
    "name": "Huijie Wei",
    "email": "hello@resolid.tech"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resolid/framework.git",
    "directory": "packages/dev"
  },
  "files": [
    "dist",
    "env.d.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./env": {
      "types": "./env.d.ts"
    },
    "./http.server": {
      "types": "./dist/http.d.mts",
      "import": "./dist/http.mjs"
    },
    "./router": {
      "types": "./dist/router.d.mts",
      "import": "./dist/router.mjs"
    },
    "./routes": {
      "types": "./dist/routes.d.mts",
      "import": "./dist/routes.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@netlify/types": "^2.8.0",
    "@resolid/utils": "^1.7.0",
    "@vercel/nft": "^1.10.2",
    "hono": "^4.12.30",
    "minimatch": "^10.2.5",
    "rolldown": "^1.2.0",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsdown": "^0.22.8"
  },
  "peerDependencies": {
    "@react-router/dev": "^8.2.0",
    "isbot": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "vite": "^8.1.4"
  },
  "engines": {
    "node": "^22.22.0 || >=24"
  }
}
