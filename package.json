{
  "name": "resolid-framework",
  "private": true,
  "description": "A modern full-stack framework for building fast, scalable, and maintainable web applications.",
  "homepage": "https://www.resolid.tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resolid/framework.git"
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=./website",
    "build": "turbo run build",
    "build:vercel": "VERCEL=1 turbo run build",
    "build:netlify": "NETLIFY=true turbo run build",
    "start:site": "pnpm run --filter ./website start:site",
    "start:admin": "pnpm run --filter ./website start:admin",
    "test:packages": "turbo run test --filter=./packages/*",
    "build:packages": "turbo run build --filter=./packages/*",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "lint": "turbo run lint",
    "format": "oxfmt",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@resolid/config": "^5.3.9",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@tailwindcss/language-server": "^0.14.29",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "^22.13.0 || >=24",
    "pnpm": "10.x"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "lefthook"
    ],
    "overrides": {
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "react-is": "^19.2.5",
      "typescript": "^6.0.3",
      "vite-node": "^6.0.0",
      "safer-buffer": "npm:@nolyfill/safer-buffer@^1"
    }
  }
}
