{
  "name": "website",
  "private": true,
  "description": "The Resolid Website.",
  "homepage": "https://www.resolid.tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resolid/framework.git",
    "directory": "website"
  },
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "oxlint",
    "start:site": "NODE_ENV=production SERVER_PORT=3001 node --env-file=.env ./build/server/site/server.mjs",
    "start:admin": "NODE_ENV=production SERVER_PORT=3002 SERVER_PATH=admin node --env-file=.env ./build/server/admin/server.mjs",
    "typecheck": "react-router typegen && tsc --noEmit",
    "typegen": "react-router typegen"
  },
  "dependencies": {
    "@logtape/file": "^2.1.4",
    "@react-router/node": "^7.17.0",
    "@resolid/app-cache": "workspace:^",
    "@resolid/app-db": "workspace:^",
    "@resolid/app-log": "workspace:^",
    "@resolid/app-mail": "workspace:^",
    "@resolid/cache-file": "workspace:^",
    "@resolid/cache-redis": "workspace:^",
    "@resolid/core": "workspace:^",
    "@resolid/react-ui": "^0.3.1",
    "@resolid/utils": "^1.6.1",
    "@tailwindcss/typography": "^0.5.20",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.7.1",
    "@vercel/speed-insights": "^2.0.0",
    "isbot": "^5.1.42",
    "mysql2": "^3.22.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.17.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@react-router/dev": "^7.17.0",
    "@resolid/dev": "workspace:^",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  }
}
